%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d64f85ba82d8a50469ee4d29937573fa, type: 3}
  m_Name: Wave 2
  m_EditorClassIdentifier: Assembly-CSharp::DialogTree
  DialogList:
  - Dialog: For would-be prey, these souls sure are bold. How annoying.
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 2480814380858620165, guid: aac327979260b43418b577b7d1ebfa3e, type: 3}
  - Dialog: "I couldn\u2019t agree more. What a horrible racket!"
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 2480814380858620165, guid: aac327979260b43418b577b7d1ebfa3e, type: 3}
  - Dialog: 'Huh? '
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: 2385674708959976505, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 2480814380858620165, guid: aac327979260b43418b577b7d1ebfa3e, type: 3}
  - Dialog: Is it usually so noisy around here, Ran?
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: 2385674708959976505, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'Yakumo? How long have you been watching? '
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -8136939511726613997, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Long enough to give up on sleep, that\u2019s for sure. You have terrible
      neighbors. "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -8136939511726613997, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -2031496893, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "It\u2019s poor enough etiquette for them to try and hunt near the residences,
      but no one\u2019s even shown up about it. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "So now it\u2019s your problem? "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -2031496893, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "So now it\u2019s my problem. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -2031496893, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'As usual, it seems. '
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Unlike your surface, it\u2019s every man for themself down here. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "\u2026Unless you want to make yourself useful."
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -2031496893, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Oh, no. Exhausted as I am? I wouldn\u2019t dare. Besides, you look like
      you\u2019ve got it handled! "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'Then get out of the way! More are coming! '
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: 794085875712075535, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
