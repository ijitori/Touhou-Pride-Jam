%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d64f85ba82d8a50469ee4d29937573fa, type: 3}
  m_Name: Intro
  m_EditorClassIdentifier: Assembly-CSharp::DialogTree
  DialogList:
  - Dialog: "\u2026That\u2019s enough for today. You\u2019ve improved significantly
      since we last met. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "Thank you, master! I\u2019ve been practicing back in the village!"
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 7a832a9e7fed8fa49a98b4b11b8c66db, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "Practicing on the\u2026 cats? That would explain why your spells are
      so scattered."
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "They\u2019re so small, and surprisingly good at dodging, master.  "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 7a832a9e7fed8fa49a98b4b11b8c66db, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "I\u2026 don\u2019t think they\u2019re the most effective targets for
      your magic. Between now and our next meeting, I\u2019d like you to challenge
      the kappa in the mountains."
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: Ugh.
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 7a832a9e7fed8fa49a98b4b11b8c66db, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "They\u2019ll be much better suited to working on complexity and aim,
      little one."
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "I hate them, though. They\u2019ll try to drown me and I\u2019ll get
      all wet! "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 7a832a9e7fed8fa49a98b4b11b8c66db, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "All the more reason to aim better, then, isn\u2019t it? "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: 'I guess. '
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 7a832a9e7fed8fa49a98b4b11b8c66db, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "Sometimes, our best lessons come from frustration. Staying comfortable
      doesn\u2019t teach us anything, does it? "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "It\u2019s not like your master would make you do that, though\u2026"
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 7a832a9e7fed8fa49a98b4b11b8c66db, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: What, Yukari-sama? Are you kidding? She was infuriating back in the day,
      before I became her shikigami.
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "\u2026Huh? Really?! You never told me about that!"
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 7a832a9e7fed8fa49a98b4b11b8c66db, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "I haven\u2019t? Are you sure you aren\u2019t just trying to put off
      training? "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "Hey, if I have to go get soaked in the river beating up the kappa, it\u2019s
      only fair."
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 7a832a9e7fed8fa49a98b4b11b8c66db, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: Sigh
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "\u2026I have time, at least. Are you familiar with the Animal Realm,
      Chen? "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "Um\u2026 maybe? "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "A sprawling metropolis of towering, concrete buildings, occupied by
      us animal spirits of Hell. To this day it is rife with chaos, and the only
      ones around to handle it was\u2026 ourselves.  "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
  - Dialog: "Yukari-sama\u2026 can attest to this. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
    PortaritRight: {fileID: -6120023263723227101, guid: cd983dff64b067b4282507d10e56493a, type: 3}
