--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d64f85ba82d8a50469ee4d29937573fa, type: 3}
  m_Name: Wave 3
  m_EditorClassIdentifier: Assembly-CSharp::DialogTree
  DialogList:
  - Dialog: "\u2026Impressive."
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5576577275052418807, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "You\u2019re still here? I thought I told you to leave!"
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "No, you didn\u2019t. You told me to get out of the way, and I did. "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5576577275052418807, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "That\u2019s too literal. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "It\u2019s fine though, isn\u2019t it? You\u2019re more than capable
      of handling this no matter where I am. "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -1596292230, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Well, I\u2019d be fighting a whole lot better if I didn\u2019t have
      to worry about you getting hurt out here. It\u2019s far too dangerous with
      such aggressive spirits around."
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -1596292230, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Awww, \u201Cworry?\u201D Since when were you so protective? "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -920390671, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: ..!
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -5143451010721637198, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -920390671, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Th-that\u2019s\u2026 Why are you here, anyways?! "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -5143451010721637198, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -920390671, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Didn\u2019t I tell you I was woken up? "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 6652828153079176658, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'I mean why were you sleeping in the metropolis? And, for that matter,
      how? '
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 6652828153079176658, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'What, is that suddenly a crime? Does the lawless Beast Realm now have
      laws on where a woman can take her naps? '
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5576577275052418807, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Don\u2019t be ridiculous. Do you think I\u2019d be fighting like this
      up here if there were laws in Hell? "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5576577275052418807, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "I don\u2019t know. Maybe? You\u2019ve always been a bit of a hothead. "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 94737884, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'Am I a hothead, or do you just irritate me? '
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 94737884, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "The former, for sure. I\u2019ve never had to try very hard. "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Then you should start trying not to push it, or I\u2019ll be using you
      as a shield this time. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "You wouldn\u2019t! "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -2028734460, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "You don\u2019t know that. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -2028734460, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'I actually know plenty about you, thank you very much. I keep excellent
      notes. '
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 6652828153079176658, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'I beg your pardon? '
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'Oh, would you look at that. We have more company! Have fun. '
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: 8195090320448324678, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
