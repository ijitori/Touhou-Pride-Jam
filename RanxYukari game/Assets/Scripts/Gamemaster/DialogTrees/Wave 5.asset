--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d64f85ba82d8a50469ee4d29937573fa, type: 3}
  m_Name: Wave 5
  m_EditorClassIdentifier: Assembly-CSharp::DialogTree
  DialogList:
  - Dialog: "\u2026So. What is it, then? "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'Hm? '
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -3127955973574677526, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Coming to such a beastly district of hell. Picking up one of its worthless,
      disembodied residents and helping me take the form I have now. Staying by my
      side\u2026 all these years. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -7075415303241466695, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -3127955973574677526, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "\u2026 "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -7075415303241466695, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 83037244, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'Why me, then? '
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -7075415303241466695, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 83037244, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'Are you upset? '
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -7075415303241466695, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "I just want you to be honest, Yakumo. You said it yourself; you aren\u2019t
      the reckless sort."
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -7075415303241466695, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'And frankly, above all else, none of us beasts are stupid enough to
      believe in altruism. So, what is it? '
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "\u2026"
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -327401834422631593, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: I want you to believe me when I say this, alright? No jokes this time.
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -1450621543, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "Whatever business I was here on when I met you is long since irrelevant.
      But the moment I laid eyes on you\u2026 I knew something was different about
      you. A look in your eyes that wanted more than your life offered."
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -1450621543, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "I see that same ambition now. Who wouldn\u2019t want to nurture it,
      and see where you go?"
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -1059647706405520586, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -920390671, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "\u2026! "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -5143451010721637198, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "I\u2026 didn\u2019t expect such an answer from you."
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -7403736139108634444, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5522366917127876498, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "You wanted honesty, didn\u2019t you? The truth is simple. You\u2019re
      thrilling to be around, Ran. On my word as a sage."
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -7403736139108634444, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: -1596292230, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "That\u2019s\u2026"
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -7403736139108634444, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 83037244, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "\u2026Even so. Surely the world above has just as many people like that,
      doesn\u2019t it? No one stifled by a land so chaotic, it becomes monotonous.
      Where you can just live.  "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: -7403736139108634444, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 83037244, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: 'Of course there are. But none of them are you. '
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: -7403736139108634444, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 5576577275052418807, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "\u2026You\u2019re impossible. "
    OnTheLeft: 1
    DialogCharacterTheme: {fileID: 11400000, guid: 60c18fb5a05c5ab46b53ec22e06c5fba, type: 2}
    PortaritLeft: {fileID: 1883140202042252782, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 83037244, guid: 058a9de5618692546851314d14ba38de, type: 3}
  - Dialog: "I think that\u2019s enough about me. You were busy, weren\u2019t you? "
    OnTheLeft: 0
    DialogCharacterTheme: {fileID: 11400000, guid: 0d020e2bce96cbd4c9d6cef78b04f046, type: 2}
    PortaritLeft: {fileID: 1883140202042252782, guid: b97f53db3650d2a479fac9e4f6ccea96, type: 3}
    PortaritRight: {fileID: 6652828153079176658, guid: 058a9de5618692546851314d14ba38de, type: 3}
